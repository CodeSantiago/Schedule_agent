---
import "../styles/app.css";
import "../styles/workspace.css";
import Topbar from "../components/Topbar.astro";

interface Props {
  title?: string;
  email?: string | null;
  barberName?: string | null;
  photoUrl?: string | null;
}

const { title = "Barber Agent — Workspace", email = null, barberName = null, photoUrl = null } = Astro.props;
const displayName = barberName || email || null;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta name="theme-color" content="#0b0c0f" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>
  <body data-context="workspace">
    <Topbar email={displayName} context="workspace" />
    {photoUrl ? (
      <div class="workspace-avatar-wrap">
        <img src={photoUrl} alt="Foto de perfil" class="workspace-avatar" />
      </div>
    ) : null}
    <main class="workspace-page">
      <slot />
    </main>
  </body>
</html>
