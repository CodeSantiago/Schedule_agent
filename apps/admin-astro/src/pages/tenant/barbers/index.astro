---
import TenantBase from "../../../layouts/TenantBase.astro";
import { getTenantPrincipal } from "../../../lib/session";
import { apiFetch, apiJson, ApiError } from "../../../lib/api";

const principal = await getTenantPrincipal(Astro.cookies, Astro.request);
if (principal === null) {
  return Astro.redirect("/tenant/login");
}

interface Barber {
  id: string;
  name: string;
  restrictions: string | null;
  is_active: boolean;
}

let barbers: Barber[] = [];
let flash: string | null = null;
let error: string | null = null;
const url = Astro.url.pathname;

// ── Handle POST: create | toggle ─────────────────────────────────------
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("_action") ?? "");

  try {
    if (action === "create") {
      const name = String(form.get("name") ?? "").trim();
      const restrictions = String(form.get("restrictions") ?? "").trim() || null;

      if (!name) {
        error = "El nombre es obligatorio.";
      } else {
        await apiFetch(`/tenants/${principal.tenant_id}/barbers`, {
          method: "POST",
          request: Astro.request,
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ name, restrictions }),
        });
        flash = `Barbero "${name}" creado.`;
      }
    } else if (action === "toggle") {
      const barberId = String(form.get("barber_id") ?? "");
      const currentActive = form.get("is_active") === "true";
      const barberName = String(form.get("barber_name") ?? "");

      await apiFetch(`/tenants/${principal.tenant_id}/barbers/${barberId}`, {
        method: "PUT",
        request: Astro.request,
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ is_active: !currentActive }),
      });
      flash = currentActive
        ? `Barbero "${barberName}" desactivado.`
        : `Barbero "${barberName}" activado.`;
    }
  } catch (err: unknown) {
    if (err instanceof ApiError) {
      const detail =
        (err.body as { detail?: string } | null | undefined)?.detail;
      error = detail ?? `Operación fallida (${err.status}).`;
    } else {
      error = "No se pudo contactar la API.";
    }
  }
}

// ── Fetch barbers (always, to reflect current state) ───────────────────
try {
  barbers = await apiJson<Barber[]>(
    `/tenants/${principal.tenant_id}/barbers`,
    { request: Astro.request },
  );
} catch (err: unknown) {
  if (err instanceof ApiError) {
    error = `No se pudieron cargar los barberos (${err.status}).`;
  } else {
    error = "Could not reach the API.";
  }
}
---

<TenantBase title="Barberos — Barber Agent" email={principal.email}>
  <section class="card">
    <div class="card-header">
      <div>
        <span class="card-eyebrow">Barberos</span>
        <h1>Barberos</h1>
        <p class="card-subtitle">
          Gestiona tus barberos: crea, edita y alterna disponibilidad.
        </p>
      </div>
      <div class="card-actions">
        <a class="btn small ghost" href="/tenant/dashboard">Volver a inicio</a>
      </div>
    </div>

    {flash && <div class="flash">{flash}</div>}
    {error && <p class="form-error">{error}</p>}

    <!-- ── Inline create form ─────────────────────────────────────── -->
    <form method="post" action={url} class="form">
      <input type="hidden" name="_action" value="create" />
      <div class="form-grid-2">
        <label>
          Nombre
          <input
            type="text"
            name="name"
            required
            maxlength="120"
            placeholder="ej. Carlos"
          />
        </label>
        <label>
          Restricciones
          <input
            type="text"
            name="restrictions"
            maxlength="64"
            placeholder="ej. SOLO_CORTE (opcional)"
          />
        </label>
      </div>
      <div class="form-footer">
        <button type="submit" class="btn primary">Agregar barbero</button>
      </div>
    </form>
  </section>

  <!-- ── Barbers table ──────────────────────────────────────────── -->
  <section class="card">
    {barbers.length === 0 ? (
      <div class="empty-state">
        <p>Aún no hay barberos. Crea uno arriba.</p>
      </div>
    ) : (
      <table class="grid">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Restricciones</th>
            <th>Activo</th>
            <th class="actions">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {barbers.map((b) => (
            <tr>
              <td>
                <strong>{b.name}</strong>
              </td>
              <td class="muted-2">{b.restrictions ?? "—"}</td>
              <td>
                {b.is_active
                  ? <span class="status status-active">Activo</span>
                  : <span class="status status-suspended">Inactivo</span>}
              </td>
              <td class="actions">
                <a
                  class="btn small"
                  href={`/tenant/barbers/${b.id}/edit`}
                >
                  Editar
                </a>
                <form method="post" action={url} style="display:inline;">
                  <input type="hidden" name="_action" value="toggle" />
                  <input type="hidden" name="barber_id" value={b.id} />
                  <input type="hidden" name="barber_name" value={b.name} />
                  <input type="hidden" name="is_active" value={String(b.is_active)} />
                  <button type="submit" class="btn small {b.is_active ? 'ghost' : 'primary'}">
                    {b.is_active ? "Desactivar" : "Activar"}
                  </button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </section>
</TenantBase>
