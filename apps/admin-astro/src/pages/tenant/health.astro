---
import TenantBase from "../../layouts/TenantBase.astro";
import { getTenantPrincipal } from "../../lib/session";
import { apiJson, ApiError } from "../../lib/api";

const principal = await getTenantPrincipal(Astro.cookies, Astro.request);
if (principal === null) {
  return Astro.redirect("/tenant/login");
}

interface HealthData {
  tenant_id: string;
  bot: { enabled: boolean; greeting_configured: boolean; behavior_notes_set: boolean; display_name_configured: boolean };
  sheets: { connected: boolean; config_label: string | null; spreadsheet_configured: boolean };
  data_policy: { source_of_truth: string; sync_mode: string };
  counts: { active_barbers: number; total_barbers: number; active_services: number; total_services: number; upcoming_appointments: number };
  recent_issues: Array<{ event_type: string; level: string; message: string; created_at: string }>;
  providers: Array<{ kind: string; label: string; is_active: boolean; provider_name: string }>;
  overall: string;
}

let health: HealthData | null = null;
let loadError: string | null = null;

try {
  health = await apiJson<HealthData>(
    `/tenants/${principal.tenant_id}/health`,
    { request: Astro.request },
  );
} catch (err: unknown) {
  if (err instanceof ApiError) {
    loadError = `No se pudo cargar el estado de salud (${err.status}).`;
  } else {
    loadError = "No se pudo contactar la API.";
  }
}

function overallBadge(overall: string): string {
  const map: Record<string, string> = { healthy: "status-active", attention: "status-suspended", critical: "status-churned" };
  return map[overall] ?? "status-trial";
}

function overallLabel(overall: string): string {
  const map: Record<string, string> = {
    healthy: "Saludable",
    attention: "Atención",
    critical: "Crítico",
  };
  return map[overall] ?? overall;
}

function sourceLabel(source: string): string {
  const map: Record<string, string> = {
    database: "Base de datos",
    google_sheets: "Google Sheets",
    hybrid: "Híbrido",
  };
  return map[source] ?? source;
}

function syncLabel(mode: string): string {
  const map: Record<string, string> = {
    manual: "Manual",
    import_only: "Solo importar",
    import_export: "Importar y exportar",
  };
  return map[mode] ?? mode;
}
---

<TenantBase title="Centro de salud — Barber Agent" email={principal.email}>
  <section class="card">
    <div class="card-header">
      <div>
        <span class="card-eyebrow">Operaciones</span>
        <h1>Centro de salud</h1>
        <p class="card-subtitle">Estado operativo en tiempo real de tu barbería.</p>
      </div>
      <div class="card-actions">
        <a class="btn small" href="/tenant/dashboard">Volver a inicio</a>
      </div>
    </div>

    {loadError && <p class="form-error">{loadError}</p>}

    {health && (
      <>
        <!-- Overall status -->
        <div class="cards">
          <div class="kpi">
            <div class="kpi-label">Estado general</div>
            <div style="margin-top:4px;">
              <span class={`status ${overallBadge(health.overall)}`}>{overallLabel(health.overall)}</span>
            </div>
          </div>
          <div class="kpi">
            <div class="kpi-label">Bot</div>
            <div class="kpi-value" style="font-size:16px;">
              {health.bot.enabled
                ? <span class="status status-active">ENCENDIDO</span>
                : <span class="status status-churned">APAGADO</span>}
            </div>
          </div>
          <div class="kpi">
            <div class="kpi-label">Google Sheets</div>
            <div class="kpi-value" style="font-size:16px;">
              {health.sheets.connected
                ? <span class="status status-active">conectado</span>
                : <span class="status status-suspended">no conectado</span>}
            </div>
          </div>
          <div class="kpi">
            <div class="kpi-label">Fuente de datos</div>
            <div class="kpi-value" style="font-size:14px; margin-top:6px;">{sourceLabel(health.data_policy.source_of_truth)}</div>
          </div>
          <div class="kpi">
            <div class="kpi-label">Modo de sincronización</div>
            <div class="kpi-value" style="font-size:14px; margin-top:6px;">{syncLabel(health.data_policy.sync_mode)}</div>
          </div>
          <div class="kpi">
            <div class="kpi-label">Próximas reservas</div>
            <div class="kpi-value">{health.counts.upcoming_appointments}</div>
          </div>
          <div class="kpi">
            <div class="kpi-label">Barberos activos</div>
            <div class="kpi-value">{health.counts.active_barbers}/{health.counts.total_barbers}</div>
          </div>
          <div class="kpi">
            <div class="kpi-label">Servicios activos</div>
            <div class="kpi-value">{health.counts.active_services}/{health.counts.total_services}</div>
          </div>
        </div>

        <!-- Provider connections -->
        {health.providers.length > 0 && (
          <div class="card-section">
            <div class="card-section-head">
              <h2>Conexiones de proveedores</h2>
            </div>
            <table class="grid">
              <thead>
                <tr>
                  <th>Tipo</th>
                  <th>Etiqueta</th>
                  <th>Proveedor</th>
                  <th>Estado</th>
                </tr>
              </thead>
              <tbody>
                {health.providers.map(p => (
                  <tr>
                    <td><code>{p.kind}</code></td>
                    <td>{p.label}</td>
                    <td><code>{p.provider_name}</code></td>
                    <td>
                      {p.is_active
                        ? <span class="status status-active">activo</span>
                        : <span class="status status-suspended">inactivo</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        <!-- Recent issues -->
        {health.recent_issues.length > 0 && (
          <div class="card-section">
            <div class="card-section-head">
              <h2>Incidencias recientes</h2>
            </div>
            <div class="ts-log-list">
              {health.recent_issues.map(e => (
                <div class={`ts-log-row ts-log-${e.level}`}>
                  <div class="ts-log-meta">
                    <span class={`ts-log-level ts-log-level-${e.level}`}>{e.level}</span>
                    <span class="ts-log-type">{e.event_type}</span>
                    <span class="ts-log-date">{new Date(e.created_at).toLocaleString()}</span>
                  </div>
                  <div class="ts-log-msg">{e.message}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {health.recent_issues.length === 0 && (
          <div class="card-section">
            <div class="card-section-head">
              <h2>Incidencias recientes</h2>
            </div>
            <p class="muted">Sin incidencias recientes. Todo parece estar bien.</p>
          </div>
        )}
      </>
    )}
  </section>
</TenantBase>
