# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://barber:barber@localhost:5432/barber_agent

# ── API server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENV=development

# ── Admin dashboard (Astro) ──────────────────────────────────────────────────
# The Astro dashboard (apps/admin-astro/) is a separate Node process.
# Set API_BASE_URL so the dashboard can reach the FastAPI JSON API in
# production.  In dev the Vite proxy handles it.
API_BASE_URL=http://localhost:8000
ADMIN_PORT=4321
ADMIN_HOST=0.0.0.0

# ── Kapso / WhatsApp Cloud API ───────────────────────────────────────────────
#
# KAPSO_API_KEY is the GLOBAL, platform-level API key shared across all
# tenants.  Each tenant that uses Kapso can reference it by setting
# ``credentials.api_key_ref`` to ``"global"`` (or leaving it blank) in its
# provider_configs row.  A tenant that needs a different key can set
# ``api_key_ref`` to the per-tenant override value instead.
#
# KAPSO_BASE_URL is the default Kapso platform base URL; individual
# tenants can override it via their provider_configs.settings
# (platform_base_url key).
#
# When KAPSO_API_KEY is NOT set, the KapsoTransport returns
# ``delivered=False`` with a clear error message — it does NOT silently
# succeed or fall back to a no-op.
KAPSO_API_KEY=
KAPSO_BASE_URL=https://graph.facebook.com/v22.0

# ── Kapso webhook secret ─────────────────────────────────────────────────────
# Per-tenant webhook_secret is stored in the provider_configs.credentials
# JSONB column (set via the admin dashboard).  The platform-level fallback
# below is used when the per-tenant value is empty.
KAPSO_WEBHOOK_SECRET=

# ── OpenRouter (LLM intent classifier) ───────────────────────────────────────
#
# When OPENROUTER_API_KEY is set, the webhook route uses an
# OpenRouterIntentClassifier that makes real HTTP calls to the
# OpenRouter Chat Completions API.  Without it, the deterministic
# pure-Python classifier is used — the webhook never crashes just
# because the LLM key is missing.
#
# OPENROUTER_BASE_URL can be overridden for self-hosted / proxy setups.
# OPENROUTER_MODEL defaults to "openrouter/free" (the free-tier router
# which picks the cheapest available model).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free

# ── Production hardening: Redis (optional, graceful degredation) ─────────────
# Set REDIS_URL to enable Redis-backed coordination (locking, dedup, queue).
# When not set, all features degrade gracefully to null implementations
# that remain safe for development and testing.
#
# REDIS_ENABLED=true can be used instead of a URL to enable Redis with
# the default localhost:6379 connection.
#
# REDIS_URL=redis://localhost:6379/0
# REDIS_ENABLED=false

# ── Background queue ─────────────────────────────────────────────────────────
# BACKGROUND_QUEUE=threaded   — runs tasks in a thread pool (production)
# BACKGROUND_QUEUE=inprocess  — runs tasks inline (default, dev)
# In production (ENV=production), threaded is the default.
# BACKGROUND_QUEUE=inprocess

# ── Dedup / burst window ─────────────────────────────────────────────────────
# DEDUP_WINDOW_SECONDS=10    — time window for content-based burst suppression
# LOCK_TTL_SECONDS=30        — max time for a conversation lock to be held
